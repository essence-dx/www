{
  "schema": "dx.www.conversion_route_discovery",
  "purpose": "Single DX-WWW, DX CLI, and Zed index for the source-owned conversion proof routes.",
  "discovery_consumers": [
    "dx-www",
    "dx-cli",
    "zed"
  ],
  "routing": {
    "canonical": "dx-www",
    "no_next_router": true,
    "no_tanstack_router": true,
    "no_react_router": true,
    "route_file_kind": "dx-www .html",
    "runtime_policy": "source-only launch proof; no server, build, or hosted backend execution"
  },
  "acceptance_checklist": "forge/acceptance/no-runtime-route-acceptance.json",
  "rendered_proof_receipt_schema": "forge/acceptance/rendered-proof-evidence.schema.json",
  "rendered_proof_validator": "forge/acceptance/validate-rendered-proof-evidence.ts",
  "blocked_rendered_proof_fixture": "forge/acceptance/fixtures/blocked-rendered-proof.sample.json",
  "rendered_proof_import_plan": "forge/acceptance/rendered-proof-import-plan.json",
  "rendered_proof_import_tool": "forge/acceptance/prepare-rendered-proof-import.ts",
  "rendered_proof_review_tool": "forge/acceptance/review-rendered-proof-completeness.ts",
  "rendered_proof_runtime_approval_request": "forge/acceptance/rendered-proof-runtime-approval-request.json",
  "rendered_proof_runtime_approval_tool": "forge/acceptance/request-rendered-proof-runtime-approval.ts",
  "rendered_proof_authoring_guide": "forge/acceptance/rendered-proof-evidence-authoring-guide.json",
