      "data-dx-route",
      "data-dx-source",
      "data-dx-forge",
      "data-dx-package",
      "data-dx-hot-reload-target",
      "data-surface-map",
      "data-visual-audit"
    ],
    "selection_policy": "Open the converted .html page first, then the matching source surface map, visual audit, conversion manifest, and receipt.",
    "runtime_policy": "Selectors are source metadata only and do not start a server, hydrate React, or call hosted backends."
  },
  "routes": [
    {
      "route": "/",
      "source_project": "dx-website-startpage",
