{
  "identifier": "dx-mobile-companion",
  "description": "Allows the DX Mobile companion window to use pairing, chat, secure-store status, and QR scanner commands on mobile.",
  "windows": ["main"],
  "platforms": ["iOS", "android"],
  "permissions": [
    "core:default",
    "allow-dx-mobile-companion-contract",
    "allow-dx-mobile-credential-store-status",
    "allow-dx-mobile-parse-pairing-payload",
    "allow-dx-mobile-store-device-credential",
    "allow-dx-mobile-load-device-credential",
    "allow-dx-mobile-clear-device-credential",
    "allow-dx-mobile-scan-pairing-qr",
    "barcode-scanner:allow-check-permissions",
    "barcode-scanner:allow-request-permissions",
    "barcode-scanner:allow-open-app-settings",
    "barcode-scanner:allow-scan",
    "barcode-scanner:allow-cancel"
  ]
}
